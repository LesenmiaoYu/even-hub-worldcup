{
  "name": "even-hub-worldcup",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "tsx watch --env-file-if-exists=.env server/index.ts",
    "dev:all": "concurrently -n vite,server 'npm:dev' 'npm:server'",
    "pack": "npm run build && evenhub pack app.json dist -o even-hub-worldcup.ehpk",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.7.3",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "flag-icons": "^7.5.0",
    "happy-dom": "^20.10.2",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "upng-js": "^2.1.0"
  }
}
