# Personal-host build profile. Copy to .env.personal and fill in.
# .env.personal is gitignored — never commit secrets.
#
# Used by:
#   - vite build --mode personal     (bakes VITE_SERVER_URL into the bundle)
#   - scripts/prepack.mjs --mode personal  (writes app.packed.json whitelist)
#   - npm run pack:personal           (orchestrates both → wc-personal.ehpk)

# Absolute HTTPS URL of YOUR publicly-reachable Node server (server/).
# Examples:
#   VITE_SERVER_URL=https://wc.yulesenmiao.com
#   VITE_SERVER_URL=https://david-wc.trycloudflare.com
#   VITE_SERVER_URL=https://david-wc.ts.net
# Notes:
#   - MUST be HTTPS — the Even App rejects http:// origins in prod.
#   - MUST be reachable from the phone (not localhost / not LAN-only).
#   - This exact origin gets baked into the .ehpk in two places:
#       1. EventSource(`${VITE_SERVER_URL}/events`) in the JS bundle
#       2. app.packed.json permissions[network].whitelist[0]
#     Mismatch = silent failure on device.
VITE_SERVER_URL=https://CHANGE-ME.example.com
