# Copy to `.env` and fill in. `.env` is gitignored — never commit secrets.

# ── Server (Node) ─────────────────────────────────────────────────────────
# iSports Football API key — REQUIRED. The server hydrates from iSports
# on boot and polls /livescores/changes + /events continuously.
# Subscribe to the "Live Data" plan ($49 WC 2026 promo) at
# https://www.isportsapi.com — the free trial caps at 200 calls/day and
# the pollers will exhaust it in minutes.
ISPORTS_API_KEY=your_key_here

# Port the Node SSE server listens on. Defaults to 3001.
# PORT=3001

# ── Client (.ehpk build) ──────────────────────────────────────────────────
# Absolute URL of the public-facing Node server. Baked into the bundle at
# build time (Vite reads VITE_* vars). Leave UNSET for dev — the vite
# proxy in vite.config.ts forwards /events to localhost:3001.
# Production example: VITE_SERVER_URL=https://wc.yulesenmiao.com
# VITE_SERVER_URL=
