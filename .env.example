# Copy to `.env` and fill in. `.env` is gitignored — never commit your key.
#
# iSports Football API key. Required when ENABLE_ISPORTS=true. Get one
# from https://www.isportsapi.com/ (Product 219 = FIFA World Cup 2026).
ISPORTS_API_KEY=your_key_here

# Toggle live mode. Default (unset / false / 0 / no) keeps the server on
# the mock seed in server/seed.ts. Truthy values: true / 1 / yes.
ENABLE_ISPORTS=false
